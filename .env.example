# ============================================================
# Local services (consumed by docker compose AND by the app)
# Copy this file to .env.local and fill in real values.
# docker compose auto-loads .env.local via env_file:
# ============================================================
# Postgres container reads POSTGRES_* natively. The app also
# reads the same names, so no duplication.
POSTGRES_USER=ops
POSTGRES_PASSWORD=change_me_strong_pw
POSTGRES_DB=ops_console

# App-side connection params for the local DB.
# Host port is 5433 (container's 5432 is mapped out to 5433 to avoid
# colliding with a system Postgres, e.g. brew postgresql@15).
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5433

# n8n reads N8N_BASIC_AUTH_* natively.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_pw

# ============================================================
# ICS  —  Postgres (VPN required to reach)
# ============================================================
ICS_DB_HOST=
ICS_DB_PORT=5432
ICS_DB_NAME=
ICS_DB_USER=
ICS_DB_PASSWORD=
ICS_DB_SSL=false

# ============================================================
# SCADA  —  SQL Server (AVEVA Edge 2023, "Edge DB")
# Same instance runs the historian; connection is hard-capped
# at pool max=2 and uses READ UNCOMMITTED isolation.
# ============================================================
SCADA_DB_HOST=
SCADA_DB_PORT=1433
SCADA_DB_NAME=Edge DB
SCADA_DB_USER=
SCADA_DB_PASSWORD=
SCADA_DB_ENCRYPT=false
SCADA_DB_TRUST_CERT=true

# ============================================================
# Revenue DBs — PostgreSQL (per-client reporting portals)
# Three separate databases at 172.16.10.107:5432 (same VPN as ICS):
#   - mara_reporting  (projects JV2, JV3, OCEAN_MARA_GENERAL)
#   - nd_reporting    (project JV5)
#   - zp_reporting    (projects JV1-1, JV1-2, JV4)
# Same read-only user/password for the three.
# ============================================================
REVENUE_DB_HOST=
REVENUE_DB_PORT=5432
REVENUE_DB_USER=
REVENUE_DB_PASSWORD=

# ============================================================
# Anthropic API (analytics chat module — Claude Sonnet 4.6 + Haiku 4.5)
# Get yours at https://console.anthropic.com (Settings → API Keys).
# Subscription Pro/Max does NOT include API access — separate billing.
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Auth — NextAuth.js (Auth.js v5)
# AUTH_SECRET: generate with `openssl rand -base64 32`
# ============================================================
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ============================================================
# App
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
