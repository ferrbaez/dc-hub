# ============================================================
# Local services (Docker)
# ============================================================
LOCAL_DB_USER=ops
LOCAL_DB_PASSWORD=change_me_strong_pw
LOCAL_DB_NAME=ops_console
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432

N8N_USER=admin
N8N_PASSWORD=change_me_strong_pw

# ============================================================
# ICS  —  Postgres (VPN required to reach)
# ============================================================
ICS_DB_HOST=
ICS_DB_PORT=5432
ICS_DB_NAME=
ICS_DB_USER=
ICS_DB_PASSWORD=
ICS_DB_SSL=false

# ============================================================
# SCADA  —  SQL Server (AVEVA Edge 2023, "Edge DB")
# Same instance runs the historian; connection is hard-capped
# at pool max=2 and uses READ UNCOMMITTED isolation.
# ============================================================
SCADA_DB_HOST=
SCADA_DB_PORT=1433
SCADA_DB_NAME=Edge DB
SCADA_DB_USER=
SCADA_DB_PASSWORD=
SCADA_DB_ENCRYPT=false
SCADA_DB_TRUST_CERT=true

# ============================================================
# App
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
