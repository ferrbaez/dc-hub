{
  "name": "dc-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "healthcheck": "tsx --conditions=react-server --env-file=.env.local scripts/healthcheck.ts",
    "user:create": "tsx --conditions=react-server --env-file=.env.local scripts/user-create.ts",
    "new:module": "tsx scripts/new-module.ts",
    "modules:rebuild": "tsx scripts/modules-rebuild.ts",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@tanstack/react-query": "^5.59.20",
    "@tremor/react": "^3.18.7",
    "@trpc/client": "^11.0.0-rc.648",
    "@trpc/react-query": "^11.0.0-rc.648",
    "@trpc/server": "^11.0.0-rc.648",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.460.0",
    "mssql": "^11.0.1",
    "next": "^15.0.3",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "lefthook": "^1.7.22",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
